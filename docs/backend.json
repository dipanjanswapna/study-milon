{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique ID of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        },
        "role": {
          "type": "string",
          "description": "The role of the user, e.g., 'student' or 'admin'.",
          "enum": [
            "student",
            "admin"
          ]
        },
        "subjects": {
          "type": "array",
          "description": "A list of the user's study subjects.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "uid",
        "email",
        "role"
      ]
    },
    "Goal": {
      "title": "User Goal",
      "description": "A daily goal for a user.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the goal."
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the goal has been completed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the goal was created."
        }
      },
      "required": [
        "text",
        "completed",
        "createdAt"
      ]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "Represents a single study session for a user.",
      "type": "object",
      "properties": {
        "duration": {
          "type": "number",
          "description": "The duration of the study session in minutes."
        },
        "subject": {
          "type": "string",
          "description": "The subject studied during the session."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the study session was completed."
        }
      },
      "required": [
        "duration",
        "subject",
        "createdAt"
      ]
    },
    "Resource": {
      "title": "Resource",
      "description": "A study resource, such as a link or a document URL.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the resource."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the resource."
        },
        "type": {
          "type": "string",
          "description": "The type of resource.",
          "enum": [
            "link",
            "pdf"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the resource was added."
        }
      },
      "required": [
        "title",
        "url",
        "type",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": {
        "$ref": "#/entities/Goal"
      },
      "description": "Stores the daily goals for a specific user."
    },
    "/users/{userId}/studySessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/StudySession"
      },
      "description": "Stores the study sessions for a specific user."
    },
    "/users/{userId}/resources/{resourceId}": {
      "schema": {
        "$ref": "#/entities/Resource"
      },
      "description": "Stores saved resources like links and documents for a user."
    }
  }
}
