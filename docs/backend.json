
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "religion": { "type": "string", "enum": ["Muslim", "Hindu"], "default": "Muslim" },
        "total_study_minutes": { "type": "number" },
        "daily_study_minutes": { "type": "number" },
        "weekly_study_minutes": { "type": "number" },
        "monthly_study_minutes": { "type": "number" },
        "yearly_study_minutes": { "type": "number" },
        "daily_goal_minutes": { "type": "number" },
        "last_active_date": { "type": "string", "format": "date-time" },
        "last_study_day": { "type": "string", "description": "YYYY-MM-DD" },
        "last_study_week": { "type": "string", "description": "Friday_YYYY-MM-DD" },
        "last_study_month": { "type": "string", "description": "YYYY-MM" },
        "last_study_year": { "type": "string", "description": "YYYY" },
        "category": { "type": "string", "enum": ["SSC", "HSC", "Admission 1st", "Admission 2nd", "Job Prep", "University"] },
        "batch": { "type": "string" },
        "institution": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "groupId": { "type": "string", "description": "The ID of the group the user belongs to." },
        "pinnedExamId": { "type": "string", "nullable": true },
        "currentSession": {
          "type": "object",
          "properties": {
            "startTime": { "type": "number" },
            "duration": { "type": "number" },
            "status": { "type": "string", "enum": ["active", "paused", "idle"] },
            "subjectId": { "type": "string" },
            "chapterId": { "type": "string" },
            "isBreak": { "type": "boolean" }
          }
        },
        "focusSettings": {
          "type": "object",
          "properties": {
            "blockFbReels": { "type": "boolean", "default": false },
            "blockInstaReels": { "type": "boolean", "default": false },
            "blockYoutubeShorts": { "type": "boolean", "default": false },
            "restrictMessenger": { "type": "boolean", "default": false },
            "restrictWhatsapp": { "type": "boolean", "default": false },
            "blockSpotify": { "type": "boolean", "default": false },
            "blockWattpad": { "type": "boolean", "default": false },
            "strictMode": { "type": "boolean", "default": false }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "A group of students studying together.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "batch": { "type": "string" },
        "creatorId": { "type": "string" },
        "moderators": { "type": "array", "items": { "type": "string" } },
        "memberCount": { "type": "number" },
        "memberLimit": { "type": "number", "default": 15 },
        "discordLink": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorId", "category"]
    },
    "Exam": {
      "title": "Exam Schedule",
      "description": "An upcoming exam date and countdown.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "examDate": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "examDate", "category"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Stores global exam schedules."
    }
  }
}
