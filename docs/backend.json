
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique ID of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        },
        "role": {
          "type": "string",
          "description": "The role of the user, e.g., 'student' or 'admin'.",
          "enum": [
            "student",
            "admin"
          ]
        },
        "total_study_minutes": {
          "type": "number",
          "description": "Total study minutes since the beginning."
        },
        "daily_study_minutes": {
          "type": "number",
          "description": "Total study minutes for the current day."
        },
        "last_active_date": {
          "type": "string",
          "format": "date",
          "description": "Last date the user was active to reset daily minutes."
        }
      },
      "required": [
        "uid",
        "email",
        "role"
      ]
    },
    "Subject": {
      "title": "Subject",
      "description": "Represents a user-defined study subject.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the subject."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "createdAt"
      ]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Represents a chapter within a subject.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "completed",
            "revision"
          ]
        },
        "time_spent": {
          "type": "number",
          "description": "in minutes"
        },
        "revision_count": {
          "type": "number"
        },
        "last_revision_date": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "createdAt",
        "status",
        "time_spent",
        "revision_count"
      ]
    },
    "StudyTask": {
      "title": "Study Task",
      "description": "A specific study task assigned to a date.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "chapterId": { "type": "string" },
        "subjectName": { "type": "string" },
        "chapterName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectId", "chapterId", "date", "completed"]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": {
        "$ref": "#/entities/Subject"
      },
      "description": "Stores the subjects for a specific user."
    },
    "/users/{userId}/subjects/{subjectId}/chapters/{chapterId}": {
      "schema": {
        "$ref": "#/entities/Chapter"
      },
      "description": "Stores the chapters for a specific subject."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/StudyTask"
      },
      "description": "Stores daily study tasks for a user."
    }
  }
}
